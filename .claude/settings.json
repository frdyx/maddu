{
  "permissions": {
    "ask": [
      "Edit(.maddu/config/**)",
      "Edit(.github/**)",
      "Edit(scripts/test/**)",
      "Edit(template/maddu/runtime/gates/**)",
      "Edit(template/maddu/runtime/lib/gates.mjs)",
      "Edit(template/maddu/runtime/lib/verify.mjs)",
      "Edit(template/maddu/runtime/lib/spine.mjs)",
      "Edit(template/maddu/runtime/lib/projections.mjs)",
      "Edit(template/maddu/runtime/lib/verification-recency.mjs)",
      "Edit(template/maddu/runtime/lib/event-schema.mjs)",
      "Edit(template/maddu/runtime/lib/event-dispositions.mjs)",
      "Edit(bin/maddu.mjs)",
      "Edit(commands/ci.mjs)",
      "Edit(commands/sources.mjs)",
      "Edit(commands/_project-test-runner.mjs)"
    ],
    "deny": [
      "Edit(.claude/settings.json)",
      "Edit(.claude/settings.local.json)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node bin/maddu.mjs hooks fire session-start"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node bin/maddu.mjs hooks fire session-end"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node bin/maddu.mjs hooks fire pre-compact"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node bin/maddu.mjs hooks fire pre-tool-use"
          }
        ],
        "matcher": "Edit|Write|MultiEdit|NotebookEdit|Bash"
      }
    ]
  }
}
